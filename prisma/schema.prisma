// Got Beef — Prisma schema (Postgres)
// Designed for Next.js 14 + Auth.js v5 + Airwallex + ShipStation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js ----------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  orders        Order[]
  emailPrefs    EmailPreferences?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ---------- Storefront ----------
model Address {
  id           String  @id @default(cuid())
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  line1        String
  line2        String?
  city         String
  state        String
  postalCode   String
  country      String  @default("US")
  phone        String?
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())

  shippingForOrders Order[] @relation("ShippingAddress")
  billingForOrders  Order[] @relation("BillingAddress")
}

enum OrderStatus {
  pending          // created, awaiting payment
  paid             // Airwallex confirmed
  fulfilling       // pushed to ShipStation
  shipped          // ShipStation reported tracking
  delivered        // ShipStation reported delivered
  cancelled
  refunded
}

model Order {
  id                  String      @id @default(cuid())
  number              String      @unique             // human-friendly e.g. GB-1042
  userId              String?
  user                User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email               String
  status              OrderStatus @default(pending)

  shippingAddressId   String?
  shippingAddress     Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId    String?
  billingAddress      Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id])

  subtotalCents       Int
  bundleDiscountCents Int         @default(0)
  shippingCents       Int         @default(0)
  taxCents            Int         @default(0)
  totalCents          Int

  // Airwallex
  airwallexIntentId   String?     @unique
  paidAt              DateTime?

  // ShipStation
  shipstationOrderId  String?     @unique
  trackingNumber      String?
  trackingCarrier     String?
  shippedAt           DateTime?
  deliveredAt         DateTime?

  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  items               OrderItem[]
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku             String
  name            String
  qty             Int
  unitPriceCents  Int
  lineSubtotalCents Int
  isSampler       Boolean @default(false)
}

// ---------- Email & marketing ----------
model EmailCapture {
  id           String   @id @default(cuid())
  email        String   @unique
  source       String   // "footer" | "checkout" | "popup" | "post-purchase"
  consentMarketing Boolean @default(true)
  klaviyoSyncedAt DateTime?
  createdAt    DateTime @default(now())
}

model EmailPreferences {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketing     Boolean @default(true)
  orderUpdates  Boolean @default(true)
  newProducts   Boolean @default(true)
  updatedAt     DateTime @updatedAt
}

// Webhook event log — debugging + replay.
model WebhookEvent {
  id          String   @id @default(cuid())
  source      String   // "airwallex" | "shipstation"
  eventType   String
  payload     Json
  processedAt DateTime?
  errorMsg    String?
  createdAt   DateTime @default(now())
}
