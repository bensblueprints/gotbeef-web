# --- Database (Supabase Postgres) ---
# Same Supabase project as Benji AI Empire; Got Beef uses schema `gotbeef` (not `public`).
# Dashboard: https://supabase.com/dashboard/project/<project-ref>/settings/database
# Runtime (Netlify / Next.js): Transaction pooler, port 6543, add ?schema=gotbeef
DATABASE_URL="postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&schema=gotbeef"

# --- Auth (NextAuth / Auth.js v5) ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# --- Email ---
RESEND_API_KEY=""
RESEND_FROM="orders@gotbeef.us"

# --- Brevo (newsletter list; see src/lib/integrations/klaviyo.ts) ---
BREVO_API_KEY=""
BREVO_LIST_ID=""

# --- Airwallex ---
AIRWALLEX_CLIENT_ID=""
AIRWALLEX_API_KEY=""
AIRWALLEX_WEBHOOK_SECRET=""
AIRWALLEX_ENV="demo"  # demo | prod

# --- ShipStation ---
SHIPSTATION_API_KEY=""
SHIPSTATION_API_SECRET=""
SHIPSTATION_STORE_ID=""
SHIPSTATION_WEBHOOK_SECRET=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://gotbeef.us"
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_CENTS="5000"
ADMIN_EMAIL_ALLOWLIST="ben@advancedmarketing.co"

# --- Image generation (scripts/generate-bag-mockups.mjs) ---
FAL_KEY=""
